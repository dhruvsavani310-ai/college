<%- include('../partials/header') %>

<div class="container d-flex align-items-center justify-content-center min-vh-100">
    <div class="card shadow-lg border-0" style="width: 100%; max-width: 450px; border-radius: 1rem;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <i class="fa-solid fa-graduation-cap fa-3x text-primary mb-3"></i>
                <h3 class="fw-bold">Attendance System</h3>
                <p class="text-muted">Login to your account</p>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <form action="/auth/login" method="POST">
                <div class="mb-3">
                    <label for="login_id" class="form-label">Email or Student ID</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fa-solid fa-user text-muted"></i></span>
                        <input type="text" class="form-control" id="login_id" name="login_id" placeholder="Enter Email or ID" required>
                    </div>
                </div>
                
                <div class="mb-4">
                    <label for="password" class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fa-solid fa-lock text-muted"></i></span>
                        <input type="password" class="form-control" id="password" name="password" placeholder="Enter password" required>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 0.5rem;">
                    Sign In <i class="fa-solid fa-arrow-right ms-1"></i>
                </button>
            </form>
            
            <div class="text-center mt-4 text-muted small">
                Default Admin: admin@example.com / password123
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
