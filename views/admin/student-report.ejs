<%- include('../partials/header') %>
<div class="d-flex">
    <%- include('../partials/admin-sidebar') %>
    <div class="content-wrapper p-4">
        <div class="mb-4">
            <a href="/admin/students" class="text-decoration-none"><i class="fa-solid fa-arrow-left me-2"></i> Back to Students</a>
        </div>
        
        <div class="row">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body text-center p-4">
                        <i class="fa-solid fa-user-graduate fa-4x text-secondary mb-3"></i>
                        <h4 class="mb-1"><%= student.full_name %></h4>
                        <p class="text-muted mb-2"><%= student.course %> - Sem <%= student.semester %></p>
                        <span class="badge bg-primary fs-6"><%= student.student_id %></span>
                    </div>
                </div>
                
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Attendance Overview</h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Total Classes
                                <span class="badge bg-secondary rounded-pill"><%= stats.total %></span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Present
                                <span class="badge bg-success rounded-pill"><%= stats.present %></span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Absent
                                <span class="badge bg-danger rounded-pill"><%= stats.absent %></span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Leave
                                <span class="badge bg-warning text-dark rounded-pill"><%= stats.leave %></span>
                            </li>
                        </ul>
                        <div class="mt-4 text-center">
                            <h1 class="display-4 fw-bold <%= stats.percentage < 75 ? 'text-danger' : 'text-success' %>">
                                <%= stats.percentage %>%
                            </h1>
                            <p class="text-muted">Overall Attendance</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-0">
                        <div class="p-4 border-bottom">
                            <h5 class="fw-bold mb-0">Attendance History</h5>
                        </div>
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table class="table table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if(records.length === 0) { %>
                                        <tr><td colspan="2" class="text-center py-4">No attendance records found</td></tr>
                                    <% } %>
                                    <% records.forEach(record => { %>
                                    <tr>
                                        <td><%= record.attendance_date %></td>
                                        <td>
                                            <% if(record.status === 'Present') { %>
                                                <span class="badge bg-success">Present</span>
                                            <% } else if (record.status === 'Absent') { %>
                                                <span class="badge bg-danger">Absent</span>
                                            <% } else { %>
                                                <span class="badge bg-warning text-dark">Leave</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>
