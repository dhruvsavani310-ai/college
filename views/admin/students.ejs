<%- include('../partials/header') %>
<div class="d-flex">
    <%- include('../partials/admin-sidebar') %>
    <div class="content-wrapper p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="mb-0">Manage Students</h3>
            <a href="/admin/students/add" class="btn btn-primary"><i class="fa-solid fa-plus me-2"></i> Add Student</a>
        </div>
        
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <form action="/admin/students" method="GET" class="row g-3">
                    <div class="col-md-6">
                        <input type="text" name="search" class="form-control" placeholder="Search by name, ID or email..." value="<%= search %>">
                    </div>
                    <div class="col-md-4">
                        <select name="course" class="form-select">
                            <option value="">All Courses</option>
                            <% courses.forEach(c => { %>
                                <option value="<%= c.course %>" <%= selectedCourse === c.course ? 'selected' : '' %>><%= c.course %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Filter</button>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Student ID</th>
                                <th>Name</th>
                                <th>Course</th>
                                <th>Sem</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(students.length === 0) { %>
                                <tr><td colspan="6" class="text-center py-4">No students found</td></tr>
                            <% } %>
                            <% students.forEach(student => { %>
                            <tr>
                                <td><span class="badge bg-secondary"><%= student.student_id %></span></td>
                                <td class="fw-bold"><%= student.full_name %></td>
                                <td><%= student.course %></td>
                                <td><%= student.semester %></td>
                                <td>
                                    <% if(student.status === 'active') { %>
                                        <span class="badge bg-success">Active</span>
                                    <% } else { %>
                                        <span class="badge bg-danger">Inactive</span>
                                    <% } %>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="/admin/report/<%= student.id %>" class="btn btn-info" title="Report"><i class="fa-solid fa-chart-pie"></i></a>
                                        <a href="/admin/students/view/<%= student.id %>" class="btn btn-secondary" title="View"><i class="fa-solid fa-eye"></i></a>
                                        <a href="/admin/students/edit/<%= student.id %>" class="btn btn-primary" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                        <form action="/admin/students/delete/<%= student.id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this student?');">
                                            <button type="submit" class="btn btn-danger" title="Delete"><i class="fa-solid fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>
