<%- include('../partials/header') %>
<div class="d-flex">
    <%- include('../partials/student-sidebar') %>
    <div class="content-wrapper p-4">
        <h3 class="mb-4">Student Dashboard</h3>
        
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center">
                        <h5 class="fw-bold mb-4">Attendance Summary</h5>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="p-3 bg-light rounded">
                                    <h6 class="text-muted mb-1">Total Classes</h6>
                                    <h3><%= stats.total %></h3>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 bg-success bg-opacity-10 rounded text-success">
                                    <h6 class="mb-1">Present</h6>
                                    <h3><%= stats.present %></h3>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 bg-danger bg-opacity-10 rounded text-danger">
                                    <h6 class="mb-1">Absent</h6>
                                    <h3><%= stats.absent %></h3>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 bg-warning bg-opacity-10 rounded text-warning text-dark">
                                    <h6 class="mb-1">Leave</h6>
                                    <h3><%= stats.leave %></h3>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4">
                            <h2 class="display-5 fw-bold <%= stats.percentage < 75 ? 'text-danger' : 'text-success' %>">
                                <%= stats.percentage %>%
                            </h2>
                            <p class="text-muted">Overall Attendance Percentage</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 d-flex flex-column align-items-center justify-content-center">
                        <h5 class="fw-bold mb-4 align-self-start">Attendance Chart</h5>
                        <% if(stats.total > 0) { %>
                            <div style="width: 300px; height: 300px;">
                                <canvas id="attendanceChart" data-present="<%= stats.present %>" data-absent="<%= stats.absent %>" data-leave="<%= stats.leave %>"></canvas>
                            </div>
                        <% } else { %>
                            <div class="text-muted text-center py-5">
                                <i class="fa-solid fa-chart-pie fa-3x mb-3 opacity-50"></i>
                                <p>No attendance data available yet.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const canvas = document.getElementById('attendanceChart');
        if (!canvas) return; // Exit if there's no chart data

        const present = parseInt(canvas.getAttribute('data-present')) || 0;
        const absent = parseInt(canvas.getAttribute('data-absent')) || 0;
        const leave = parseInt(canvas.getAttribute('data-leave')) || 0;

        const ctx = canvas.getContext('2d');
        const myChart = new Chart(ctx, {
            type: 'pie',
            data: {
                labels: ['Present', 'Absent', 'Leave'],
                datasets: [{
                    data: [present, absent, leave],
                    backgroundColor: [
                        '#198754', // success
                        '#dc3545', // danger
                        '#ffc107'  // warning
                    ],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    });
</script>

<%- include('../partials/footer') %>
