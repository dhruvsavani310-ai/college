<%- include('../partials/header') %>
<div class="d-flex">
    <%- include('../partials/student-sidebar') %>
    <div class="content-wrapper p-4">
        <h3 class="mb-4">My Profile</h3>
        
        <div class="card border-0 shadow-sm" style="max-width: 600px;">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <% if(student.profile_photo) { %>
                        <img src="<%= student.profile_photo %>" alt="Profile" class="rounded-circle shadow-sm" style="width: 120px; height: 120px; object-fit: cover;">
                    <% } else { %>
                        <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 120px; height: 120px;">
                            <i class="fa-solid fa-user-graduate fa-4x text-secondary"></i>
                        </div>
                    <% } %>
                    <h4 class="mt-3 mb-1 fw-bold"><%= student.full_name %></h4>
                    <span class="badge bg-primary"><%= student.student_id %></span>
                </div>
                
                <ul class="list-group list-group-flush mt-4">
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span class="text-muted"><i class="fa-solid fa-envelope me-2"></i> Email</span>
                        <span class="fw-bold"><%= student.email %></span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span class="text-muted"><i class="fa-solid fa-phone me-2"></i> Phone</span>
                        <span class="fw-bold"><%= student.phone || 'N/A' %></span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span class="text-muted"><i class="fa-solid fa-book me-2"></i> Course</span>
                        <span class="fw-bold"><%= student.course %></span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span class="text-muted"><i class="fa-solid fa-calendar-alt me-2"></i> Semester</span>
                        <span class="fw-bold"><%= student.semester %></span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <span class="text-muted"><i class="fa-solid fa-circle-check me-2"></i> Account Status</span>
                        <% if(student.status === 'active') { %>
                            <span class="badge bg-success">Active</span>
                        <% } else { %>
                            <span class="badge bg-danger">Inactive</span>
                        <% } %>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>
